{% extends 'layouts/app.twig' %}

{% block title %}Users{% endblock %}
{% block page_title %}User Management{% endblock %}

{% block content %}

<div class="stats-grid" style="grid-template-columns:repeat(4,1fr);margin-bottom:24px;">
    <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-users"></i></div>
        <div class="stat-value">{{ stats.total ?? 0 }}</div>
        <div class="stat-label">Total Users</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(239,68,68,0.12);color:#ef4444"><i class="fas fa-user-shield"></i></div>
        <div class="stat-value">{{ stats.admins ?? 0 }}</div>
        <div class="stat-label">Admins</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(99,102,241,0.12);color:var(--accent)"><i class="fas fa-user-tie"></i></div>
        <div class="stat-value">{{ stats.managers ?? 0 }}</div>
        <div class="stat-label">Managers</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon" style="background:rgba(34,197,94,0.12);color:#22c55e"><i class="fas fa-check-circle"></i></div>
        <div class="stat-value">{{ stats.active ?? 0 }}</div>
        <div class="stat-label">Active</div>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <span class="card-title">{{ pagination.total ?? 0 }} Users</span>
        <a href="/users/create" class="btn btn-primary btn-sm"><i class="fas fa-user-plus"></i> Add User</a>
    </div>

    {% if users %}
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>User</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Last Login</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
            <tr>
                <td>
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div style="width:38px;height:38px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:700;font-size:14px;color:white;overflow:hidden;flex-shrink:0;">
                            {% if user.avatar %}
                            <img src="{{ user.avatar }}" style="width:100%;height:100%;object-fit:cover">
                            {% else %}
                            {{ user.full_name|default(user.username)|first|upper }}
                            {% endif %}
                        </div>
                        <div>
                            <div style="font-weight:600;color:var(--text-primary);">{{ user.full_name ?? user.username }}</div>
                            <div style="font-size:12px;color:var(--text-muted);">{{ user.email }}</div>
                        </div>
                    </div>
                </td>
                <td>
                    <span class="badge {% if user.role == 'admin' %}badge-danger{% elseif user.role == 'manager' %}badge-primary{% else %}badge-secondary{% endif %}">
                        {{ user.role|title }}
                    </span>
                </td>
                <td>
                    <span class="badge {% if user.is_active %}badge-success{% else %}badge-secondary{% endif %}">
                        {{ user.is_active ? 'Active' : 'Suspended' }}
                    </span>
                </td>
                <td class="text-sm text-muted">
                    {{ user.last_login_at ? user.last_login_at|time_ago : 'Never' }}
                </td>
                <td class="text-sm text-muted" style="white-space:nowrap;">
                    {{ user.created_at|date('M j, Y') }}
                </td>
                <td>
                    <div style="display:flex;gap:6px;">
                        <a href="/users/{{ user.id }}/edit" class="btn btn-secondary btn-icon btn-sm" title="Edit">
                            <i class="fas fa-pen"></i>
                        </a>
                        {% if user.id != auth.id %}
                        <form action="/users/{{ user.id }}/delete" method="POST">
                            <input type="hidden" name="_token" value="{{ csrf_token() }}">
                            <button class="btn btn-danger btn-icon btn-sm"
                                    data-confirm="Delete user {{ user.username }}?" title="Delete">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {% if pagination.last_page > 1 %}
    <div class="pagination">
        {% for p in range(1, pagination.last_page) %}
        <a href="?page={{ p }}" class="page-link {% if p == pagination.page %}active{% endif %}">{{ p }}</a>
        {% endfor %}
    </div>
    {% endif %}

    {% else %}
    <div class="empty-state">
        <i class="fas fa-users"></i>
        <h3>No users found</h3>
        <a href="/users/create" class="btn btn-primary">Add First User</a>
    </div>
    {% endif %}
</div>

{% endblock %}
