{% extends 'layouts/app.twig' %}

{% block title %}{{ user and user.id is defined ? 'Edit User' : 'Create User' }}{% endblock %}
{% block page_title %}{{ user and user.id is defined ? 'Edit User' : 'Create User' }}{% endblock %}

{% block content %}

<div style="max-width:560px;">
    <div class="card">
        <div class="card-header">
            <span class="card-title">{{ user and user.id is defined ? 'Edit User' : 'New User' }}</span>
            <a href="/users" class="btn btn-secondary btn-sm"><i class="fas fa-arrow-left"></i> Back</a>
        </div>
        <div class="card-body">
            <form action="{{ user and user.id is defined ? '/users/' ~ user.id ~ '/edit' : '/users/create' }}" method="POST">
                <input type="hidden" name="_token" value="{{ csrf_token() }}">

                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input type="text" name="full_name" class="form-control" value="{{ user.full_name ?? '' }}" placeholder="John Doe">
                </div>

                <div class="form-group">
                    <label class="form-label">Username *</label>
                    <input type="text" name="username" class="form-control {% if errors.username is defined %}error{% endif %}"
                           value="{{ user.username ?? '' }}" placeholder="johndoe"
                           {% if user and user.id is defined %}readonly style="opacity:0.6"{% else %}required{% endif %}>
                    {% if errors.username is defined %}<div class="form-error">{{ errors.username }}</div>{% endif %}
                </div>

                <div class="form-group">
                    <label class="form-label">Email *</label>
                    <input type="email" name="email" class="form-control {% if errors.email is defined %}error{% endif %}"
                           value="{{ user.email ?? '' }}" placeholder="john@example.com" required>
                    {% if errors.email is defined %}<div class="form-error">{{ errors.email }}</div>{% endif %}
                </div>

                {% if not (user and user.id is defined) %}
                <div class="form-group">
                    <label class="form-label">Password *</label>
                    <input type="password" name="password" class="form-control {% if errors.password is defined %}error{% endif %}"
                           minlength="8" required placeholder="Min. 8 characters">
                    {% if errors.password is defined %}<div class="form-error">{{ errors.password }}</div>{% endif %}
                </div>
                {% endif %}

                <div class="grid-2">
                    <div class="form-group">
                        <label class="form-label">Role</label>
                        <select name="role" class="form-control">
                            {% for role in roles %}
                            <option value="{{ role }}" {% if (user.role ?? 'manager') == role %}selected{% endif %}>
                                {{ role|title }}
                            </option>
                            {% endfor %}
                        </select>
                    </div>

                    {% if user and user.id is defined %}
                    <div class="form-group">
                        <label class="form-label">&nbsp;</label>
                        <label style="display:flex;align-items:center;gap:8px;cursor:pointer;padding:10px 0;">
                            <input type="checkbox" name="is_active" {% if user.is_active %}checked{% endif %}
                                   style="width:16px;height:16px;accent-color:var(--accent)">
                            <span>Active Account</span>
                        </label>
                    </div>
                    {% endif %}
                </div>

                <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:8px;">
                    <a href="/users" class="btn btn-secondary">Cancel</a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-{{ user and user.id is defined ? 'save' : 'user-plus' }}"></i>
                        {{ user and user.id is defined ? 'Save Changes' : 'Create User' }}
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}
