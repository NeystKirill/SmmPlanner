{
    "name": "smm/planner",
    "description": "SMM Planner - Social Media Management Dashboard",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "nikic/fast-route": "^1.3",
        "twig/twig": "^3.8",
        "twig/extra-bundle": "*",
        "twig/intl-extra": "^3.8",
        "vlucas/phpdotenv": "^5.6",
        "ramsey/uuid": "^4.7",
        "respect/validation": "^2.3",
        "monolog/monolog": "^3.5",
        "phpmailer/phpmailer": "^6.9",
        "intervention/image": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
